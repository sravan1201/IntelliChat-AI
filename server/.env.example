# ─── IntelliChat AI — Environment Variables ─────────────────────
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# MongoDB (leave empty for demo mode)
MONGODB_URI=mongodb://localhost:27017/intellichat

# JWT Secret (change in production!)
JWT_SECRET=intellichat_secret_key_change_me_in_production

# Google Gemini API Key (leave empty for demo mode with mock responses)
GEMINI_API_KEY=

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
